# FortiAIGate Terraform Deployment — Example Variable Values
#
# Copy this file to terraform.tfvars and fill in the required values.
#
# PREREQUISITES before running terraform apply:
#   1. AWS CLI configured with credentials (aws configure or IAM role)
#   2. FortiAIGate images pushed to your container registry

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# Common registry prefix for all FortiAIGate service images.
# Each image is pulled as:  <image_repository>/<service>:<image_tag>
# Example services: api, core, webui, logd, license_manager, scanner,
#                   custom-triton, triton-models
image_repository = "123456789.dkr.ecr.us-east-1.amazonaws.com/fortiaigate"

# ---------------------------------------------------------------------------
# Common optional settings
# ---------------------------------------------------------------------------

aws_region   = "us-east-1"
cluster_name = "fortiaigate"
image_tag    = "V8.0.0-build0024"

# ---------------------------------------------------------------------------
# GPU support (disabled by default — adds one g5.2xlarge node)
# ---------------------------------------------------------------------------

gpu_enabled = false
# gpu_node_instance_type = "g5.2xlarge"

# ---------------------------------------------------------------------------
# Ingress
# ---------------------------------------------------------------------------

ingress_class = "nginx"
ingress_host  = ""  # e.g. "fortiaigate.example.com"

# For AWS ALB ingress with HTTPS:
# ingress_class = "alb"
# ingress_host  = "fortiaigate.example.com"
# ingress_annotations = {
#   "kubernetes.io/ingress.class"                  = "alb"
#   "alb.ingress.kubernetes.io/scheme"             = "internet-facing"
#   "alb.ingress.kubernetes.io/target-type"        = "ip"
#   "alb.ingress.kubernetes.io/listen-ports"       = "[{\"HTTPS\":443}]"
#   "alb.ingress.kubernetes.io/backend-protocol"   = "HTTPS"
#   "alb.ingress.kubernetes.io/certificate-arn"    = "arn:aws:acm:us-east-1:123456789:certificate/..."
# }

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------

storage_size = "100Gi"

# ---------------------------------------------------------------------------
# Licenses
# ---------------------------------------------------------------------------
# Map of EKS node name -> local path to .lic file.
# Node names are available after the cluster is created:
#   kubectl get nodes -o custom-columns=NAME:.metadata.name --no-headers
#
# You can apply the cluster first (terraform apply -target=module.eks),
# retrieve node names, then fill this in and run terraform apply again.

licenses = {
  # "ip-10-0-1-100.us-east-1.compute.internal" = "/path/to/node1.lic"
  # "ip-10-0-2-200.us-east-1.compute.internal" = "/path/to/node2.lic"
}
